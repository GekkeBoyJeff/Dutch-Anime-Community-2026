# ════════════════════════════════════════════════════════════════════
#  .env.example — Dutch Anime Community 2026   (committed template)
#  Copy this file to .env.local and fill in your values. .env.local is
#  gitignored; server-only keys (without NEXT_PUBLIC_) never reach the
#  browser bundle. Every variable is validated at startup by src/lib/env.ts.
# ════════════════════════════════════════════════════════════════════

# ── Supabase — required (Supabase → Project Settings → API) ───────────
# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# anon / public key — may be public; RLS is the security boundary
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — SECRET. Build/CI only (bypasses RLS). Never client-side.
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase database password (for running the migrations) ───────────
# The password you chose when creating the project:
SUPABASE_DB_PASSWORD=YOUR_DB_PASSWORD_HERE
# Optional: the full connection string from
# Supabase → Project Settings → Database → Connection string → "Session mode"
# (replace [YOUR-PASSWORD] with your password). Set this and the schema SQL
# can be run directly instead of pasting it into the SQL editor.
# SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD_HERE@db.<ref>.supabase.co:5432/postgres

# ── Local dev (optional — defaults are fine) ──────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# /builder is already on in dev; the below is only needed for a local prod/static build:
# NEXT_PUBLIC_ENABLE_BUILDER=true
# HOST_TYPE=static            # only to test a static export locally
# NEXT_PUBLIC_BASE_PATH=      # empty = domain root (as on DirectAdmin)

# ── Optional app secrets & flags (empty/unset = off) ──────────────────
# Gates the content inspector (/api/get-page-by-path) and draft-mode toggle
# (/api/draft) in production; send as the x-debug-secret header. Empty = open
# in dev, closed (404) in production.
# DEBUG_SECRET=
# Gates the on-demand revalidation webhook (/api/revalidate); the CMS sends it
# as x-revalidate-secret. Empty = the endpoint 404s.
# REVALIDATE_SECRET=
# PWA (Serwist offline service worker), off by default. Requires the webpack
# build: `ENABLE_PWA=true next build --webpack` (not a plain Turbopack build).
# ENABLE_PWA=true

# ════════════════════════════════════════════════════════════════════
#  ⚠️  DO NOT FILL THESE IN THIS FILE.
#  These are NOT app variables — they are secrets that belong in GitHub
#  Actions and in Supabase Edge Functions. Listed here only as a checklist
#  so you can collect them; they get set with `gh secret set` /
#  `supabase secrets set`.
# ════════════════════════════════════════════════════════════════════
#
#  GitHub Actions secrets (Phase 8 — build + SFTP to DirectAdmin):
#    NEXT_PUBLIC_SUPABASE_URL        → same as above
#    NEXT_PUBLIC_SUPABASE_ANON_KEY   → same as above
#    SUPABASE_SERVICE_ROLE_KEY       → same as above
#    SITE_URL                        → https://<your-live-domain>
#    SFTP_HOST                       → <directadmin host or IP>
#    SFTP_USER                       → <directadmin user>
#    SFTP_PASSWORD                   → <directadmin password>   (or an SSH key)
#    SFTP_REMOTE_DIR                 → /domains/<domain>/public_html
#
#  Supabase Edge Function secrets (Phase 8 — the "Publish" button):
#    GITHUB_DISPATCH_TOKEN           → fine-grained PAT, this repo only, contents:write
#    GITHUB_REPO                     → GekkeBoyJeff/Dutch-Anime-Community-2026
