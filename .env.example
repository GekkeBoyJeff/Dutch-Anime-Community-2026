# Copy this file to .env.local and set your values. .env.local is gitignored (see .gitignore); this
# committed file is the template + the list of every variable the app and its build read. Each is
# validated at startup by src/lib/env.ts (a malformed value fails the build). Uncomment a line to set it.

# ── Runtime ────────────────────────────────────────────────────────────────────

# Public site URL — metadata, canonical/OG URLs, sitemap, robots and JSON-LD. The NEXT_PUBLIC_ prefix
# inlines it into the browser bundle (intentional: the URL is public). Falls back to the value below.
NEXT_PUBLIC_SITE_URL=https://example.com

# Server-only secret (no NEXT_PUBLIC_ prefix, so it never reaches the browser). Gates the content
# inspector (GET /api/getpagebypath) and the draft-mode toggle (GET /api/draft) in production — empty
# means open in dev / closed in production. Set a long random value, then send it as x-debug-secret.
DEBUG_SECRET=

# Server-only secret for the on-demand revalidation webhook (POST /api/revalidate). A future CMS sends
# it as the x-revalidate-secret header. Empty = the endpoint 404s.
REVALIDATE_SECRET=

# ── Build & deploy flags (optional; the deploy workflow sets these for you) ────────

# PWA — the Serwist offline service worker, off by default. It requires the webpack build (see README),
# so don't enable it for a plain Turbopack build.
# ENABLE_PWA=true

# Build target — 'static' produces a static export for a static host; unset = the default server build.
# HOST_TYPE=static

# Subpath the site is served under (e.g. /my-app on a static host); pairs with HOST_TYPE=static.
# NEXT_PUBLIC_BASE_PATH=/my-app

# NODE_ENV is set automatically by Next (development / production / test) — never set it here.
