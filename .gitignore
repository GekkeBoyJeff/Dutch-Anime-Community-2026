# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/

# serwist (generated service worker)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js

# Builder media manifest (regenerated by scripts/generate-builder-manifest.mjs via `npm run images`)
/public/builder-images.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env*
!.env.example

# storybook
/storybook-static

# vitest / coverage
/coverage

# typescript / sass caches
*.tsbuildinfo
.sass-cache

# Ignore the docs/ working area (plans, specs, notes) but keep the generated codebase report,
# which the README links to (a directory-level `docs/` ignore would block these negations, so
# ignore the contents instead and re-include the report + tour).
docs/*
!docs/codebase-report.md
!docs/codebase-report.html

#next-env
next-env.d.ts
# Generated from src/styles/breakpoints.json by styles.config.mjs
src/styles/_breakpoints.scss

# Build-time responsive image variants (regenerated by scripts/optimize-images.mjs)
public/media/_opt/

# Vendored Ghostscript-WASM runtime (copied from node_modules by scripts/copy-gs-wasm.mjs)
public/gs/gs.js
public/gs/gs.wasm

# Claude / AI tooling artifacts (not part of the app; docs/ above is also ignored)
.claude/
.superpowers/

