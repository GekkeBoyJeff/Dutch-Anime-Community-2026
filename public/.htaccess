<IfModule mod_headers.c>
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://qwzvjgqdamsruyaaqubg.supabase.co; font-src 'self'; connect-src 'self' https://qwzvjgqdamsruyaaqubg.supabase.co wss://qwzvjgqdamsruyaaqubg.supabase.co; frame-src 'self' https://www.youtube-nocookie.com https://player.vimeo.com https://www.tiktok.com https://fast.wistia.net https://fast.wistia.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  # HSTS only over HTTPS (RFC 6797) — never forces HTTP-only/no-cert hosts (e.g. the test subdomain) to https.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" "expr=%{HTTPS} == 'on'"
</IfModule>

# Custom 404 (Next static export emits /404.html). Routes resolve via DirectoryIndex thanks to
# trailingSlash — no rewrite rules needed.
ErrorDocument 404 /404.html
